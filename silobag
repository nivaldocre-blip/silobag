import flet as ft
import flet_fastapi
from fastapi import FastAPI, Request
import sqlite3
import uvicorn
import os

# --- BANCO DE DADOS ---
def init_db():
    conn = sqlite3.connect("monitor.db", check_same_thread=False)
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS leituras 
                      (id INTEGER PRIMARY KEY AUTOINCREMENT, temp TEXT, hum TEXT, gas TEXT, data TIMESTAMP DEFAULT CURRENT_TIMESTAMP)''')
    conn.commit()
    return conn

db_conn = init_db()
app = FastAPI()

# --- LÓGICA DA TELA (FLET) ---
def main(page: ft.Page):
    page.title = "Monitor Silo Bag"
    page.theme_mode = ft.ThemeMode.DARK
    page.padding = 20

    lbl_temp = ft.Text("0°C", size=40, weight="bold", color="orange")
    lbl_hum = ft.Text("0%", size=40, weight="bold", color="blue")
    lbl_gas = ft.Text("0 ppm", size=40, weight="bold", color="green")

    def atualizar_tela():
        cursor = db_conn.cursor()
        cursor.execute("SELECT temp, hum, gas FROM leituras ORDER BY id DESC LIMIT 1")
        row = cursor.fetchone()
        if row:
            lbl_temp.value = f"{row[0]}°C"
            lbl_hum.value = f"{row[1]}%"
            lbl_gas.value = f"{row[2]} ppm"
            page.update()

    # Essa função será chamada via PubSub quando o ESP32 enviar dados
    def on_new_data(msg):
        atualizar_tela()

    page.pubsub.subscribe(on_new_data)

    page.add(
        ft.Text("📊 Monitoramento Silo Bag", size=30, weight="bold"),
        ft.Divider(),
        ft.Row([
            ft.Card(content=ft.Container(content=ft.Column([ft.Text("Temperatura"), lbl_temp]), padding=20)),
            ft.Card(content=ft.Container(content=ft.Column([ft.Text("Umidade"), lbl_hum]), padding=20)),
            ft.Card(content=ft.Container(content=ft.Column([ft.Text("Gás (CO2)"), lbl_gas]), padding=20)),
        ], alignment=ft.MainAxisAlignment.CENTER),
    )
    atualizar_tela()

# --- ROTA PARA O ESP32 ENVIAR DADOS ---
@app.post("/update")
async def update_data(request: Request):
    data = await request.json()
    temp = data.get("temp")
    hum = data.get("hum")
    gas = data.get("gas")
    
    cursor = db_conn.cursor()
    cursor.execute("INSERT INTO leituras (temp, hum, gas) VALUES (?, ?, ?)", (temp, hum, gas))
    db_conn.commit()
    
    # Avisa o Flet que tem dado novo para atualizar a tela
    # Nota: Em produção com múltiplos usuários, usaríamos um identificador
    flet_fastapi.send_all("/update", {"status": "ok"})
    return {"status": "success"}

# Integração Flet + FastAPI
app.mount("/", flet_fastapi.app(main))

if __name__ == "__main__":
    port = int(os.environ.get("PORT", 8080))
    uvicorn.run(app, host="0.0.0.0", port=port)
